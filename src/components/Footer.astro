---
import { SITE_DOMAIN } from '../consts';

const year = new Date().getFullYear();
---

<footer class="border-t border-line-strong pt-6.5 pb-10 font-mono text-[12.5px] text-ink-soft">
	<div
		class="mx-auto flex max-w-site flex-col gap-2 px-4 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4.5 sm:px-6"
	>
		<span class="font-semibold text-green-deep">200 OK</span>
		<span>built with astro + tailwind</span>
		<span class="sm:ml-auto">© {year} {SITE_DOMAIN}</span>
	</div>
</footer>
