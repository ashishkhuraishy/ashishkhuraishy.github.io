---
import { EMAIL, SOCIALS } from '../consts';

const links = [
	{ label: 'email', display: `${EMAIL} →`, href: `mailto:${EMAIL}` },
	{ label: 'github', display: `/${SOCIALS.github} →`, href: `https://github.com/${SOCIALS.github}` },
	{
		label: 'linkedin',
		display: `/in/${SOCIALS.linkedin} →`,
		href: `https://linkedin.com/in/${SOCIALS.linkedin}`,
	},
	{ label: 'x / twitter', display: `@${SOCIALS.twitter} →`, href: `https://x.com/${SOCIALS.twitter}` },
];
---

<section id="contact" class="border-t border-line-strong py-12 sm:py-18">
	<div
		class="grid items-center gap-6 rounded-[10px] border border-line-strong bg-panel p-5 sm:p-[26px] md:grid-cols-[1.3fr_1fr] md:gap-9 md:p-[34px]"
	>
		<div>
			<span
				class="mb-3.5 inline-block rounded-[5px] border border-line bg-panel px-2 py-0.5 font-mono text-[13px] text-ink-soft"
			>
				<b class="font-semibold text-green">POST</b> /contact
			</span>
			<h2 class="text-2xl leading-[1.15] font-bold tracking-tight sm:text-[30px]">
				Let's build something that stays up.
			</h2>
			<p class="mt-3 text-ink-soft">
				Open to interesting platform problems, Go work, and conversations about infrastructure, AI
				systems, or why your cluster is doing that.
			</p>
		</div>
		<div class="flex flex-col gap-3 font-mono text-[13px] sm:text-sm">
			{
				links.map(({ label, display, href }) => (
					<a
						href={href}
						target={href.startsWith('http') ? '_blank' : undefined}
						rel={href.startsWith('http') ? 'noopener' : undefined}
						class="flex flex-wrap justify-between gap-x-2.5 gap-y-1 rounded-[7px] border border-line px-3.5 py-3 text-ink hover:border-blue hover:text-blue hover:no-underline sm:px-4 [&:hover>.arrow]:text-blue"
					>
						<span>{label}</span>
						<span class="arrow break-all text-ink-soft">{display}</span>
					</a>
				))
			}
		</div>
	</div>
</section>
