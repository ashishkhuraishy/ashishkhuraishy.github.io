---
import TraceDiagram from './TraceDiagram.astro';
---

<div class="relative pt-12 pb-10 sm:pt-[84px] sm:pb-14">
	<p class="mb-[18px] flex items-center gap-2.5 font-mono text-[13px] tracking-wider text-blue">
		<span class="h-px w-[34px] bg-blue" aria-hidden="true"></span>
		backend · cloud · golang
	</p>
	<h1 class="max-w-[760px] text-[clamp(34px,5.6vw,62px)] leading-[1.08] font-bold tracking-[-0.022em]">
		I work on the platforms<br />other engineers <span class="text-blue">build on.</span>
	</h1>
	<p class="mt-[22px] max-w-[600px] text-base text-ink-soft sm:text-lg">
		I like finding out why things broke, fixing them properly, and building systems that scale
		and stay up. Outside of that: new tech to poke at, coffee, and football.
	</p>
	<div class="mt-[30px] flex flex-wrap gap-3.5">
		<a
			href="/#projects"
			class="inline-flex items-center gap-2 rounded-md border border-ink bg-ink px-5 py-[11px] font-mono text-sm font-medium text-white transition hover:-translate-y-px hover:no-underline hover:shadow-[0_4px_14px_rgba(11,18,32,.22)]"
		>
			view projects →
		</a>
		<a
			href="/#contact"
			class="inline-flex items-center gap-2 rounded-md border border-ink bg-panel px-5 py-[11px] font-mono text-sm font-medium text-ink transition hover:-translate-y-px hover:border-blue hover:text-blue hover:no-underline"
		>
			POST /contact
		</a>
	</div>

	<TraceDiagram />
</div>
