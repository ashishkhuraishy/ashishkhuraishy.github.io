---
import TraceDiagram from './TraceDiagram.astro';
---

<div class="relative pt-12 pb-10 sm:pt-21 sm:pb-14">
	<p class="mb-4.5 flex items-center gap-2.5 font-mono text-[13px] tracking-wider text-blue">
		<span class="hidden h-px w-8.5 bg-blue sm:block" aria-hidden="true"></span>
		backend · cloud platforms · golang
	</p>
	<h1 class="max-w-190 text-[clamp(28px,4.2vw,50px)] leading-[1.1] font-bold tracking-[-0.022em]">
		I like finding out why things<br />fall apart and building the <span class="text-blue">version that doesn't.</span>
	</h1>
	<p class="mt-5.5 max-w-150 text-base text-ink-soft sm:text-lg">
		I like finding out why things broke, fixing them properly, and building systems that scale
		and stay up. Outside of that: new tech to poke at, coffee, and football.
	</p>
	<div class="mt-7.5 flex flex-wrap gap-3.5">
		<a
			href="/#projects"
			class="inline-flex items-center gap-2 rounded-md border border-ink bg-ink px-5 py-2.75 font-mono text-sm font-medium text-white transition hover:-translate-y-px hover:no-underline hover:shadow-[0_4px_14px_rgba(11,18,32,.22)]"
		>
			view projects →
		</a>
		<a
			href="/#contact"
			class="inline-flex items-center gap-2 rounded-md border border-ink bg-panel px-5 py-2.75 font-mono text-sm font-medium text-ink transition hover:-translate-y-px hover:border-blue hover:text-blue hover:no-underline"
		>
			POST /contact
		</a>
	</div>

	<TraceDiagram />
</div>
