---
import { SITE_DOMAIN } from '../consts';

const navLinks = [
	{ href: '/#about', label: '/about' },
	{ href: '/#experience', label: '/experience' },
	{ href: '/#stack', label: '/stack' },
	{ href: '/#projects', label: '/projects' },
	{ href: '/blog', label: '/blog' },
	{ href: '/#contact', label: '/contact' },
];
---

<header class="sticky top-0 z-50 transform-gpu border-b border-line-strong bg-paper/95 backdrop-blur-sm">
	<div
		class="mx-auto flex max-w-site items-center gap-x-3 px-4 py-2.5 font-mono text-xs sm:gap-x-4 sm:px-6 sm:text-[12.5px]"
	>
		<span class="font-semibold">
			<a href="/" class="text-ink hover:no-underline">{SITE_DOMAIN}</a>
		</span>
		<span
			class="inline-flex items-center gap-1.5 rounded-full border border-green-line bg-green-dim px-2 py-px font-medium text-green-deep sm:px-2.5"
		>
			<span class="relative flex size-1.75">
				<span
					class="absolute -inset-1 animate-ping-slow rounded-full border border-green opacity-0"
				></span>
				<span class="size-1.75 rounded-full bg-green"></span>
			</span>
			<span class="hidden min-[420px]:inline">operational</span>
		</span>
		<!-- desktop nav -->
		<nav aria-label="Primary" class="ml-auto hidden gap-4.5 sm:flex">
			{
				navLinks.map(({ href, label }) => (
					<a href={href} class="text-ink-soft hover:text-blue hover:no-underline">
						{label}
					</a>
				))
			}
		</nav>
		<!-- mobile menu toggle -->
		<button
			id="nav-toggle"
			type="button"
			aria-expanded="false"
			aria-controls="mobile-nav"
			class="ml-auto cursor-pointer text-ink-soft hover:text-blue sm:hidden"
		>
			[ menu ]
		</button>
	</div>
	<!-- mobile nav panel -->
	<nav
		id="mobile-nav"
		aria-label="Primary"
		class="hidden flex-col border-t border-line bg-paper/95 px-4 py-2 font-mono text-[13px] sm:hidden!"
	>
		{
			navLinks.map(({ href, label }) => (
				<a
					href={href}
					class="border-b border-line py-2.5 text-ink-soft last:border-b-0 hover:text-blue hover:no-underline"
				>
					{label}
				</a>
			))
		}
	</nav>
</header>

<script>
	const toggle = document.getElementById('nav-toggle');
	const panel = document.getElementById('mobile-nav');
	if (toggle && panel) {
		const setOpen = (open: boolean) => {
			panel.classList.toggle('hidden', !open);
			panel.classList.toggle('flex', open);
			toggle.setAttribute('aria-expanded', String(open));
			toggle.textContent = open ? '[ close ]' : '[ menu ]';
		};
		toggle.addEventListener('click', () => {
			setOpen(panel.classList.contains('hidden'));
		});
		// close after picking a destination (anchor links stay on the page)
		panel.addEventListener('click', (e) => {
			if (e.target instanceof Element && e.target.closest('a')) setOpen(false);
		});
	}
</script>
