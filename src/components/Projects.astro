---
import { SOCIALS } from '../consts';
import SectionHead from './SectionHead.astro';

interface Project {
	repo: string;
	status: 'prod' | 'building';
	title: string;
	description: string;
	tags: string[];
	url?: string;
}

const projects: Project[] = [
	{
		repo: `github.com/${SOCIALS.github}/memstat`,
		status: 'prod',
		title: 'Memstat',
		description:
			'Go CLI that monitors RAM and CPU across multiple servers and renders the numbers as live terminal graphs. Built so I could watch my whole fleet without keeping five SSH tabs open.',
		tags: ['#go', '#cli', '#monitoring'],
		url: `https://github.com/${SOCIALS.github}/memstat`,
	},
	{
		repo: `github.com/${SOCIALS.github}/kaldi-server`,
		status: 'prod',
		title: 'Kaldi Server',
		description:
			'Docker base image for the Kaldi speech toolkit, optimised for running ASR servers on top of it. 2k+ pulls on Docker Hub from people who also didn\'t want to compile Kaldi from scratch.',
		tags: ['#docker', '#speech', '#asr'],
		url: `https://github.com/${SOCIALS.github}/kaldi-server`,
	},
	{
		repo: `github.com/${SOCIALS.github}/ashishkhuraishy.github.io`,
		status: 'building',
		title: 'This site',
		description:
			'The page you\'re reading, built with Astro, Tailwind, and an animated request trace. Permanently marked "building" because that\'s the honest status of every personal site ever made.',
		tags: ['#astro', '#wip'],
		url: `https://github.com/${SOCIALS.github}/ashishkhuraishy.github.io`,
	},
];
---

<section id="projects" class="border-t border-line-strong py-10 sm:py-18">
	<SectionHead title="Projects" path="/projects" />
	<div class="grid gap-5 [grid-template-columns:repeat(auto-fit,minmax(min(100%,290px),1fr))]">
		{
			projects.map((p) => (
				<article class="flex flex-col gap-2.5 rounded-[10px] border border-line-strong bg-panel p-4 transition hover:-translate-y-[3px] hover:border-blue hover:shadow-[0_14px_30px_-18px_rgba(15,98,254,.35)] sm:p-[22px]">
					<div class="flex items-center gap-2.5 font-mono text-xs">
						{
							p.url ? (
								<a
									href={p.url}
									target="_blank"
									rel="noopener"
									class="break-all text-ink-soft hover:text-blue"
								>
									{p.repo}
								</a>
							) : (
								<span class="break-all text-ink-soft">{p.repo}</span>
							)
						}
						<span
							class:list={[
								'ml-auto rounded-full border px-2 py-px text-[11px] font-semibold',
								p.status === 'prod'
									? 'border-green-line bg-green-dim text-green-deep'
									: 'border-[#F1C21B] bg-amber-dim text-amber-deep',
							]}
						>
							{p.status}
						</span>
					</div>
					<h3 class="text-[17.5px] font-semibold">{p.title}</h3>
					<p class="flex-1 text-[14.5px] text-ink-soft">{p.description}</p>
					<div class="flex flex-wrap gap-2 font-mono text-[11.5px] text-blue">
						{p.tags.map((tag) => (
							<span>{tag}</span>
						))}
					</div>
				</article>
			))
		}
	</div>
</section>
