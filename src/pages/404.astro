---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`404 · ${SITE_TITLE}`} description="Route not found. There is a shell here, though." />
	</head>
	<body>
		<Header />
		<main class="mx-auto w-full max-w-site px-4 sm:px-6">
			<section class="py-12 sm:py-20">
				<p class="mb-4.5 flex items-center gap-2.5 font-mono text-[13px] tracking-wider text-blue">
					<span class="h-px w-8.5 bg-blue" aria-hidden="true"></span>
					404 not found
				</p>
				<h1 class="text-[clamp(28px,4.5vw,46px)] leading-[1.12] font-bold tracking-[-0.022em]">
					This route doesn't exist.
				</h1>
				<p class="mt-3 max-w-140 text-ink-soft">
					No handler matched your request. There's a shell below if you want to look around, or
					just head <a href="/">home</a>.
				</p>

				<div
					id="term"
					class="mt-8 max-w-180 cursor-text rounded-[10px] bg-ink p-4 font-mono text-[13px] leading-[1.8] text-[#D6DEE9] shadow-[0_18px_40px_-28px_rgba(11,18,32,.5)] sm:p-6 sm:text-sm"
				>
					<div id="term-out">
						<p><span class="text-[#42be65]">$</span> GET {'<this page>'}</p>
						<p class="text-[#ff8389]">404 route not found</p>
						<p class="text-[#5b6b82]">type `help` for available commands</p>
					</div>
					<p class="flex items-center gap-2">
						<span class="text-[#42be65]">$</span>
						<label class="sr-only" for="term-in">terminal input</label>
						<input
							id="term-in"
							type="text"
							autocomplete="off"
							autocapitalize="off"
							spellcheck="false"
							class="w-full bg-transparent text-[#D6DEE9] caret-[#42be65] outline-none"
						/>
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script>
	const out = document.getElementById('term-out');
	const input = document.getElementById('term-in') as HTMLInputElement | null;
	const term = document.getElementById('term');

	const print = (text: string, cls = '') => {
		if (!out) return;
		const p = document.createElement('p');
		p.className = cls ? `whitespace-pre-wrap ${cls}` : 'whitespace-pre-wrap';
		p.textContent = text;
		out.appendChild(p);
	};

	const go = (path: string) => {
		print(`302 redirecting to ${path} ...`, 'text-[#5b6b82]');
		setTimeout(() => {
			window.location.href = path;
		}, 400);
	};

	const commands: Record<string, () => void> = {
		help: () => {
			print('available commands:');
			print('  whoami            who runs this place');
			print('  ls                list routes');
			print('  cd <route>        go somewhere (e.g. cd /projects)');
			print('  resume            plain-text resume');
			print('  clear             clear the screen');
		},
		whoami: () => {
			print('ashish · platform engineer · go, kubernetes, and things that page me');
		},
		ls: () => {
			print('/about  /experience  /stack  /projects  /blog  /contact');
		},
		resume: () => go('/resume.txt'),
		clear: () => {
			if (out) out.innerHTML = '';
		},
		exit: () => go('/'),
		home: () => go('/'),
		sudo: () => print('nice try. this is a static site.', 'text-[#ff8389]'),
	};

	const routes = ['/about', '/experience', '/stack', '/projects', '/contact'];

	const run = (raw: string) => {
		const line = raw.trim();
		if (!line) return;
		print(`$ ${line}`, 'text-[#42be65]');
		const [cmd, arg = ''] = line.split(/\s+/, 2);
		if (cmd === 'cd' || cmd === 'goto') {
			const target = arg.startsWith('/') ? arg : `/${arg}`;
			if (target === '/' || target === '/home') return go('/');
			if (target === '/blog') return go('/blog');
			if (routes.includes(target)) return go(`/#${target.slice(1)}`);
			return print(`cd: no such route: ${arg || '(none)'}`, 'text-[#ff8389]');
		}
		const handler = commands[cmd.toLowerCase()];
		if (handler) handler();
		else print(`command not found: ${cmd}. try \`help\``, 'text-[#ff8389]');
	};

	if (input && term) {
		term.addEventListener('click', () => input.focus());
		input.addEventListener('keydown', (e) => {
			if (e.key === 'Enter') {
				run(input.value);
				input.value = '';
				input.scrollIntoView({ block: 'nearest' });
			}
		});
		input.focus();
	}
</script>
