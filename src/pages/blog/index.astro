---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import SectionHead from '../../components/SectionHead.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="Notes on Go, Kubernetes, distributed systems, and things learned by building." />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-site px-4 sm:px-6">
			<section class="py-12 sm:py-18">
				<SectionHead title="Blog" path="/blog" />
				{
					posts.length === 0 ? (
						<p class="font-mono text-sm text-ink-soft">204 No Content — posts coming soon.</p>
					) : (
						<ul class="flex flex-col gap-4">
							{posts.map((post) => (
								<li>
									<a
										href={`/blog/${post.id}/`}
										class="group flex flex-col gap-1.5 rounded-[10px] border border-line-strong bg-panel p-4 text-ink transition hover:-translate-y-[2px] hover:border-blue hover:no-underline hover:shadow-[0_14px_30px_-18px_rgba(15,98,254,.35)] sm:p-[22px]"
									>
										<span class="font-mono text-xs text-ink-soft">
											<FormattedDate date={post.data.pubDate} />
										</span>
										<span class="text-[19px] font-semibold group-hover:text-blue">
											{post.data.title}
										</span>
										<span class="text-[14.5px] text-ink-soft">{post.data.description}</span>
									</a>
								</li>
							))}
						</ul>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
